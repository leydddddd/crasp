# MongoDB connection string (required for all engines to persist data)
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Local Docker: mongodb://localhost:27017
CRASP_MONGO_URI=

# Zyte Scrapy Cloud credentials (required for cloud engine only)
ZYTE_API_KEY=
CRASP_ZYTE_PROJECT=

# Optional: Scrapy feed output path (local-scrapy engine)
CRASP_FEED_URI=file:///./items.jl
